<?xml version="1.0" encoding="utf-8"?>
<!--
  Action card for AlbumPickerActivity (e.g. "Main Collection", "Remove from Album").
  Same dimensions as item_album.xml so it fits naturally in the same GridView.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Solid tinted background instead of a photo -->
    <View
        android:id="@+id/actionBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorThumbPlaceholder" />

    <!-- Centred icon + label -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <ImageView
            android:id="@+id/actionIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/actionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorToolbarText"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

</FrameLayout>
