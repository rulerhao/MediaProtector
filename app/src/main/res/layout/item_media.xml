<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">

    <!-- Thumbnail fills the cell -->
    <ImageView
        android:id="@+id/thumbnail"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:scaleType="centerCrop"
        android:background="?attr/colorThumbPlaceholder" />

    <!-- Filename overlaid at the bottom -->
    <TextView
        android:id="@+id/filename"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#B3000000"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="3dp"
        android:paddingBottom="4dp"
        android:singleLine="true"
        android:ellipsize="middle" />

    <!-- Video badge — top-right corner -->
    <TextView
        android:id="@+id/videoBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:background="@color/badge_bg"
        android:text="&#x25B6;"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone" />

    <!-- Selection dim overlay -->
    <View
        android:id="@+id/selectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@color/selection_overlay"
        android:visibility="gone" />

    <!-- Selection checkmark circle (top-right) -->
    <FrameLayout
        android:id="@+id/selectionCheck"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:background="@drawable/selection_check_bg"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="&#x2713;"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </FrameLayout>

</FrameLayout>
